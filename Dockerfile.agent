# Build the agent binary
FROM --platform=$BUILDPLATFORM golang:1.26 AS builder

ARG TARGETARCH

WORKDIR /workspace

# Copy the Go Modules manifests
COPY go.mod go.mod
COPY go.sum go.sum

# Cache deps before building and copying source so that we don't need to re-download as much
# and so that source changes don't invalidate our downloaded layer
# Set GOTOOLCHAIN=auto to allow downloading newer Go versions if required by go.mod
ENV GOTOOLCHAIN=auto
RUN go mod download

# Copy the go source
COPY cmd/ cmd/
COPY api/ api/
COPY internal/ internal/

# Build args for version injection
ARG VERSION=dev
ARG COMMIT=unknown
ARG BUILD_DATE=unknown

# Build
RUN CGO_ENABLED=0 GOOS=linux GOARCH=$TARGETARCH go build -trimpath \
    -ldflags="-s -w -X main.version=${VERSION} -X main.commit=${COMMIT} -X main.date=${BUILD_DATE}" \
    -o novaedge-agent cmd/novaedge-agent/main.go

# Agent requires iptables for TPROXY mesh interception and root for privileged
# network operations (VIP binding, BGP port 179, ARP/NDP, iptables rules)
FROM alpine:3.23
RUN apk add --no-cache iptables ip6tables iproute2
WORKDIR /
COPY --from=builder /workspace/novaedge-agent .

ENTRYPOINT ["/novaedge-agent"]
