# Release Dockerfile for novaedge-webui
# Expects pre-built frontend dist/ files in the build context
# Used by CI/release workflows to avoid Node.js under QEMU emulation
FROM nginx:1.27-alpine

# Remove default nginx config
RUN rm /etc/nginx/conf.d/default.conf

# Copy custom nginx config
COPY nginx.conf /etc/nginx/nginx.conf

# Copy entrypoint script
COPY docker-entrypoint.sh /docker-entrypoint.sh
RUN chmod +x /docker-entrypoint.sh

# Copy pre-built frontend
COPY dist/ /usr/share/nginx/html/

# Create temp directories and set permissions for non-root operation
RUN mkdir -p /tmp/client_temp /tmp/proxy_temp /tmp/fastcgi_temp /tmp/uwsgi_temp /tmp/scgi_temp && \
    chown -R 101:101 /tmp/client_temp /tmp/proxy_temp /tmp/fastcgi_temp /tmp/uwsgi_temp /tmp/scgi_temp && \
    chown -R 101:101 /var/log/nginx && \
    chown -R 101:101 /var/cache/nginx && \
    chown 101:101 /etc/nginx/nginx.conf && \
    touch /tmp/nginx.pid && chown 101:101 /tmp/nginx.pid

# Run as nginx user (uid 101)
USER 101

EXPOSE 8080

ENTRYPOINT ["/docker-entrypoint.sh"]
